	// ECAD用マクロ定義ここまで

	ctrl_alt_s: ctrl_alt_s { // シンボル一覧(AHK)
		compatible = "zmk,behavior-macro";
		#binding-cells = <0>;
		bindings
			= <&macro_press &kp LCTRL>
			// , <&macro_wait_time 40>
			, <&macro_press &kp LALT>
			, <&macro_tap &kp S>
			, <&macro_release &kp LALT>
			// , <&macro_wait_time 40>
			, <&macro_release &kp LCTRL>
			// , <&to WIN> // ADJWのベースレイヤー（例としてWINレイヤー）に戻る※rsewレイヤロック強制解除用
			;
	};	
	alt_home: alt_home { // 移動左90度回転[AHK]
		compatible = "zmk,behavior-macro";
		#binding-cells = <0>;
		bindings
			= <&macro_press &kp LALT>
			, <&macro_tap &kp HOME>
			, <&macro_release &kp LALT>
			;
    };
	alt_end: alt_end { // 移動右90度回転[AHK]
		compatible = "zmk,behavior-macro";
		#binding-cells = <0>;
		bindings
			= <&macro_press &kp LALT>
			, <&macro_tap &kp END>
			, <&macro_release &kp LALT>
			;
    };

	zip_keybind_keys_directionL: zip_keybind_keys_directionL {
			compatible = "zmk,input-processor-keybind";
			#input-processor-cells = <0>;
		track_remainders;
			bindings = <&kp RIGHT>
					  ,<&kp LEFT>
					  ,<&kp UP>
					  ,<&kp DOWN>
					  ;
			tick = <150>;
			wait-ms = <100>;
			tap-ms = <50>;
			mode = <1>;
	};
	zip_keybind_keys_directionM: zip_keybind_keys_directionM {
			compatible = "zmk,input-processor-keybind";
			#input-processor-cells = <0>;
		track_remainders;
			bindings = <&kp RIGHT>
					 , <&kp LEFT>
					 , <&kp UP>
					 , <&kp DOWN>
					 ;
			tick = <100>; // ティック間隔
			wait-ms = <5>; // 待機時間
			tap-ms = <40>; // タップ時間
	};
	zip_keybind_keys_directionH: zip_keybind_keys_directionH {
			compatible = "zmk,input-processor-keybind";
			#input-processor-cells = <0>;
		// track_remainders;
			bindings = <&kp RIGHT>
					  ,<&kp LEFT>
					  ,<&kp UP>
					  ,<&kp DOWN>
					  ;
			tick = <50>; // ティック間隔
			wait-ms = <0>; // 待機時間
			tap-ms = <50>; // タップ時間
	};
	zip_keybind_keys_file: zip_keybind_keys_file {
			compatible = "zmk,input-processor-keybind";
			#input-processor-cells = <0>;
		track_remainders;
			bindings = <&nx_pg>  // 右：次ページ切り替え
					 , <&pr_pg>  // 左：前ページ切り替え
					 , <&file_r> // 上：ファイルの切り替え逆
					 , <&file_f> // 下：ファイルの切り替え正
					 ;
			tick = <150>;
			wait-ms = <100>;
			tap-ms = <50>;
			mode = <1>;
    };
	zip_keybind_keys_ecad_rsew: zip_keybind_keys_ecad_rsew {
			compatible = "zmk,input-processor-keybind";
			#input-processor-cells = <0>;
		// track_remainders;
			bindings = <&kp C>  // 右：複写
	                 , <&kp D>  // 左：削除
					 , <&kp A>  // 上：領域移動
	                 , <&kp Z>  // 下：属性変更
					 ;
			tick = <120>; 		// 入力が継続している際、次のキー入力を発生させるまでの周期（間隔）
			wait-ms = <0>; 	// 入力を検知してから、実際に最初のキー（tap-msの開始）を押し下げるまでの遅延時間
			tap-ms = <50>; 		// キーを「押し下げている（Down）」状態の時間
			mode = <1>; 		// 通常、このモード指定は「蓄積された移動量（remainder）を考慮するかどうか」などの挙動を制御
    };
	zip_keybind_keys_ecad_ladjw: zip_keybind_keys_ecad_ladjw {
			compatible = "zmk,input-processor-keybind";
			#input-processor-cells = <0>;
		track_remainders;
			bindings = <&kp E>     // 右：文字修正
	                 , <&kp T>     // 左：文字
					 , <&ctrl_a_e> // 上：文字種別変更
					 , <&ctrl_d_e> // 下：文章修正
					 ;
			tick = <150>;
			wait-ms = <100>;
			tap-ms = <50>;
			mode = <1>;
    };
	zip_keybind_keys_ecad_radjw: zip_keybind_keys_ecad_radjw {
			compatible = "zmk,input-processor-keybind";
			#input-processor-cells = <0>;
		// track_remainders;
			bindings = <&ctrl_a_w>     // 右：渡りページ編集
	                 , <&kp R>         // 左：リファレンス編集
					 , <&ctrl_a_n>     // 上：自動線番範囲選択
					 , <&ctrl_alt_s>   // 下：シンボル一覧[AHK]
					 ;
			tick = <120>; 		// 入力が継続している際、次のキー入力を発生させるまでの周期（間隔）
			wait-ms = <0>; 	// 入力を検知してから、実際に最初のキー（tap-msの開始）を押し下げるまでの遅延時間
			tap-ms = <50>; 		// キーを「押し下げている（Down）」状態の時間
			mode = <1>; 		// 通常、このモード指定は「蓄積された移動量（remainder）を考慮するかどうか」などの挙動を制御
    };
	zip_keybind_keys_ecad_rmovw: zip_keybind_keys_ecad_rmovw {
			compatible = "zmk,input-processor-keybind";
			#input-processor-cells = <0>;
		// track_remainders;
			bindings = <&kp G>     // 右：図形グループ化
					 , <&ctrl_a_g> // 左：図形グループ化解除
	                 , <&kp W>     // 上：図形情報表示
					 , <&ctrl_a_d> // 下：補助線削除
					 ;
			tick = <120>; 		// 入力が継続している際、次のキー入力を発生させるまでの周期（間隔）
			wait-ms = <0>; 	// 入力を検知してから、実際に最初のキー（tap-msの開始）を押し下げるまでの遅延時間
			tap-ms = <50>; 		// キーを「押し下げている（Down）」状態の時間
			mode = <1>; 		// 通常、このモード指定は「蓄積された移動量（remainder）を考慮するかどうか」などの挙動を制御
    };
	zip_keybind_keys_ecad_rble: zip_keybind_keys_ecad_rble {
			compatible = "zmk,input-processor-keybind";
			#input-processor-cells = <0>;
		// track_remainders;
			bindings = <&ctrl_a_p> // 右：ページ編集
					 , <&kp P> 	   // 左：全ページ情報
	                 , <&ctrl_a_j> // 上：図面管理情報
	                 , <&ctrl_d_j> // 下：ページ管理情報
					 ;
			tick = <120>; 		// 入力が継続している際、次のキー入力を発生させるまでの周期（間隔）
			wait-ms = <0>; 	// 入力を検知してから、実際に最初のキー（tap-msの開始）を押し下げるまでの遅延時間
			tap-ms = <50>; 		// キーを「押し下げている（Down）」状態の時間
			mode = <1>; 		// 通常、このモード指定は「蓄積された移動量（remainder）を考慮するかどうか」などの挙動を制御
    };
	zip_keybind_keys_browser: zip_keybind_keys_browser {
			compatible = "zmk,input-processor-keybind";
			#input-processor-cells = <0>;
		track_remainders;
			bindings = <&kp LC(ENTER)> // 右：新しいタブで開く
	                 , <&kp LC(W)>     // 左：タブを閉じる
					 , <&kp LS(TAB)>   // 上：前の項目へ戻る
	                 , <&kp TAB>       // 下：次の項目へ進む
					 ;
			tick = <150>;
			wait-ms = <100>;
			tap-ms = <50>;
			mode = <1>;
    };
	zip_keybind_keys_browser_i: zip_keybind_keys_browser_i {
			compatible = "zmk,input-processor-keybind";
			#input-processor-cells = <0>;
		track_remainders;
			bindings = <&kp LG(T)>     // 右：新規タブを開く
	                 , <&kp LG(W)>     // 左：タブを閉じる
					 , <&kp LS(SPACE)> // 上：上へ戻る
	                 , <&kp SPACE>     // 下：下へ進む
					 ;
			tick = <150>;
			wait-ms = <100>;
			tap-ms = <50>;
			mode = <1>;
    };
	zip_keybind_keys_media: zip_keybind_keys_media {
			compatible = "zmk,input-processor-keybind";
			#input-processor-cells = <0>;
		track_remainders;
			bindings = <&kp C_FF>     // 右：早送り
					  ,<&kp C_RW>     // 左：巻き戻し
					  ,<&kp C_VOL_UP> // 上：音量アップ
					  ,<&kp C_VOL_DN> // 下：音量ダウン
					  ;
			tick = <60>;
			wait-ms = <0>;
			tap-ms = <10>;
	};

