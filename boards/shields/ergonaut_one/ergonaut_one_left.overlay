	// Ctrl + A, N: 自動線番範囲選択
	ctrl_a_n: ctrl_a_n {
		compatible = "zmk,behavior-macro";
		#binding-cells = <0>;
		bindings
			= <&macro_press &kp LCTRL>
			, <&macro_tap &kp A>, <&macro_release &kp LCTRL>
			, <&macro_tap &kp N>
			, <&macro_wait_time 80>
			, <&macro_tap &kp TAB>
			, <&macro_wait_time 50>
			, <&macro_tap &kp TAB>
			, <&macro_wait_time 50>
			, <&macro_tap &kp TAB>
			;
	};

	// Ctrl + A, O: 図形要素分解
	ctrl_a_o: ctrl_a_o {
		compatible = "zmk,behavior-macro";
		#binding-cells = <0>;
