	analog_input_listener {
		status = "okay";
		compatible = "zmk,input-listener";
		device = <&anin0>; // 左のアナログ入力デバイス (anin0) を監視
		l_layer21 {
			layers = <BLE>; // レイヤー21がアクティブな場合
			input-processors = <&zip_keybind_keys_media>; // zip_keybind_keys_media を使用
			process-next; // 他のプロセッサも処理を継続
		};
		l_layer21-prevent {
			layers = <BLE>; // レイヤー21がアクティブな場合
			input-processors = <&zip_xy_scaler 0 1>; // ジョイスティックの動きをゼロにスケーリング（無効化）
		};
		l_layer20 {
			layers = <NUM>; // レイヤー20がアクティブな場合
			input-processors = <&zip_keybind_keys_file>; // zip_keybind_keys_file を使用
			process-next; // 他のプロセッサも処理を継続
		};
		l_layer20-prevent {
			layers = <NUM>; // レイヤー20がアクティブな場合
			input-processors = <&zip_xy_scaler 0 1>; // ジョイスティックの動きをゼロにスケーリング（無効化）
		};
		l_layer19 {
			layers = <MOVW>; // レイヤー19がアクティブな場合
			input-processors = <&zip_keybind_keys_browser>; // zip_keybind_keys_browser を使用 (ECAD用)
			process-next; // 他のプロセッサも処理を継続
		};
		l_layer19-prevent {
			layers = <MOVW>; // レイヤー19がアクティブな場合
			input-processors = <&zip_xy_scaler 0 1>; // ジョイスティックの動きをゼロにスケーリング（無効化）
		};
		l_layer18 {
			layers = <MOVL>; // レイヤー18がアクティブな場合
			input-processors = <&zip_keybind_keys_browser>; // zip_keybind_keys_browser を使用 (ECAD用)
			process-next; // 他のプロセッサも処理を継続
		};
		l_layer18-prevent {
			layers = <MOVL>; // レイヤー18がアクティブな場合
			input-processors = <&zip_xy_scaler 0 1>; // ジョイスティックの動きをゼロにスケーリング（無効化）
		};
		l_layer17 {
			layers = <MOV>; // レイヤー17がアクティブな場合
			input-processors = <&zip_keybind_keys_browser_i>; // zip_keybind_keys_browser_i を使用
			process-next; // 他のプロセッサも処理を継続
		};
		l_layer17-prevent {
			layers = <MOV>; // レイヤー17がアクティブな場合
			input-processors = <&zip_xy_scaler 0 1>; // ジョイスティックの動きをゼロにスケーリング（無効化）
		};		
		l_layer16 {
			layers = <ADJW>; // レイヤー16がアクティブな場合
			input-processors = <&zip_keybind_keys_ecad_ladjw>; // zip_keybind_keys_ladjw を使用
			process-next;
		};
		l_layer16-prevent {
			layers = <ADJW>; // レイヤー16がアクティブな場合
			input-processors = <&zip_xy_scaler 0 1>; // ジョイスティックの動きをゼロにスケーリング（無効化）
		};
		l_layer15 {
			layers = <ADJL>; // レイヤー15がアクティブな場合
			input-processors = <&zip_keybind_keys_directionH>; // zip_keybind_keys_directionH を使用
			process-next;
		};
		l_layer15-prevent {
			layers = <ADJL>; // レイヤー15がアクティブな場合
			input-processors = <&zip_xy_scaler 0 1>; // ジョイスティックの動きをゼロにスケーリング（無効化）
		};
		l_layer14 {
			layers = <ADJ>; // レイヤー14がアクティブな場合
			input-processors = <&zip_keybind_keys_directionH>; // zip_keybind_keys_directionH を使用
			process-next;
		};
		l_layer14-prevent {
			layers = <ADJ>; // レイヤー14がアクティブな場合
			input-processors = <&zip_xy_scaler 0 1>; // ジョイスティックの動きをゼロにスケーリング（無効化）
		};
		l_scroll_w {
			layers = <RSEW>; // レイヤー13がアクティブな場合
			input-processors = <&zip_xy_transform (INPUT_TRANSFORM_Y_INVERT)> // Y反転
							 , <&zip_xy_scaler 32 100> // スケーリング（32/100）
							 , <&zip_xy_to_scroll_mapper>; // スクロールイベントにマッピング
		};
		l_scroll_l {
			layers = <RSEL>; // レイヤー12がアクティブな場合
			input-processors = <&zip_xy_transform (INPUT_TRANSFORM_Y_INVERT)> // Y反転
							 , <&zip_xy_scaler 32 100> // スケーリング（32/100）
							 , <&zip_xy_to_scroll_mapper>; // スクロールイベントにマッピング
		};
		l_scroll {
			layers = <RSE>; // レイヤー11がアクティブな場合
			input-processors = <&zip_xy_transform (INPUT_TRANSFORM_Y_INVERT)> // Y反転
							 , <&zip_xy_scaler 16 100> // スケーリング（16/100）
							 , <&zip_xy_to_scroll_mapper>; // スクロールイベントにマッピング
		};
		l_mouse_speed_half_w {
			layers = <LWRW>; // レイヤー10がアクティブな場合
			input-processors = <&zip_xy_transform (0)> // 変換なし (Y軸反転を無効化)
							 , <&zip_xy_scaler 40 100>; // 速度を40/100に設定 (乗数40, 除数100)
		};
		l_mouse_speed_half_l {
			layers = <LWRL>; // レイヤー9がアクティブな場合
			input-processors = <&zip_xy_transform (0)> // 変換なし (Y軸反転を無効化)
							 , <&zip_xy_scaler 40 100>; // 速度を40/100に設定 (乗数40, 除数100)
		};
		l_mouse_speed_ipad {
			layers = <LWR>; // レイヤー8がアクティブな場合
			input-processors = <&zip_xy_transform (0)> // 変換なし (Y軸反転を無効化)
							 , <&zip_xy_scaler 40 100>; // 速度を40/100に設定 (乗数40, 除数100)
		};
		l_mouse_speed_win {
			layers = <WIN>; // レイヤー7がアクティブな場合
			input-processors = <&zip_xy_transform (0)> // 変換なし (Y軸反転を無効化)
							 , <&zip_xy_scaler 90 100>; // 速度を90/100に設定 (乗数90, 除数100)
		};
		l_mouse_speed_cad {
			layers = <CAD>; // レイヤー6がアクティブな場合
			input-processors = <&zip_xy_transform (0)> // 変換なし (Y軸反転を無効化)
							 , <&zip_xy_scaler 95 100>; // 速度を95/100に設定 (乗数95, 除数100)
		};
		l_mouse_speed_nicl {
			layers = <NICL>; // レイヤー5がアクティブな場合
			input-processors = <&zip_xy_transform (0)> // 変換なし (Y軸反転を無効化)
							 , <&zip_xy_scaler 100 100>; // 速度を100/100に設定 (乗数100, 除数100)
		};
		l_mouse_speed_ngnl {
			layers = <NGNL>; // レイヤー4がアクティブな場合
			input-processors = <&zip_xy_transform (0)> // 変換なし (Y軸反転を無効化)
							 , <&zip_xy_scaler 100 100>; // 速度を100/100に設定 (乗数100, 除数100)
		};
		l_mouse_speed_lin {
			layers = <LIN>; // レイヤー3がアクティブな場合
			input-processors = <&zip_xy_transform (0)> // 変換なし (Y軸反転を無効化)
							 , <&zip_xy_scaler 100 100>; // 速度を100/100に設定 (乗数100, 除数100)
		};
		// l_mouse_speed_full_nic {
		// 	layers = <NIC>; // レイヤー2がアクティブな場合
		// 	input-processors = <&zip_xy_transform (0)> // 変換なし (Y軸反転を無効化)
		// 					 , <&zip_xy_scaler 100 100>; // 速度を100/100に設定 (乗数100, 除数100)
		// };
		l_mouse_speed_full_nic-prevent {
			layers = <NIC>; // レイヤー2がアクティブな場合
			input-processors = <&zip_xy_scaler 0 1>; // ジョイスティックの動きをゼロにスケーリング（無効化）
		};
		l_mouse_speed_full_ngn {
			layers = <NGN>; // レイヤー1がアクティブな場合
			input-processors = <&zip_xy_transform (0)> // 変換なし (Y軸反転を無効化)
							 , <&zip_xy_scaler 100 100>; // 速度を100/100に設定 (乗数100, 除数100)
		};
		l_mouse_speed_full {
			layers = <QWE>; // レイヤー0（デフォルト）がアクティブな場合
			input-processors = <&zip_xy_transform (0)> // 変換なし (Y軸反転を無効化)
							 , <&zip_xy_scaler 100 100>; // 速度を100/100に設定 (乗数100, 除数100)
		};
	};
};

