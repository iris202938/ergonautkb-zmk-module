	// Ctrl + A, W: 渡りページ編集
	ctrl_a_w: ctrl_a_w {
		compatible = "zmk,behavior-macro";
		#binding-cells = <0>;
		bindings
			= <&macro_press &kp LCTRL>
			, <&macro_tap &kp A>, <&macro_release &kp LCTRL>
			, <&macro_tap &kp W>
			;
	};

	// Ctrl + A, X: 範囲切断
	ctrl_a_x: ctrl_a_x {
		compatible = "zmk,behavior-macro";
		#binding-cells = <0>;
		bindings
			= <&macro_press &kp LCTRL>
			, <&macro_tap &kp A>, <&macro_release &kp LCTRL>
			, <&macro_tap &kp X>
