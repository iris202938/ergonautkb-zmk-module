#include "ergonaut_one.dtsi"
#include <zephyr/dt-bindings/input/input-event-codes.h>
#include <input/processors.dtsi>
#include <dt-bindings/zmk/input_transform.h>
#include <dt-bindings/zmk/keys.h>
#include <behaviors/naginata.dtsi>
#include <dt-bindings/zmk/pointing.h> // pointing.h はマウス機能に必要です
// #include <behaviors/input_gestures_accel.dtsi>

#define ZMK_POINTING_DEFAULT_MOVE_VAL 600   // default: 600
#define ZMK_POINTING_DEFAULT_SCRL_VAL 10    // default: 10

#define QWE 0
#define NGN 1
#define NIC 2
#define LIN 3
#define NGNL 4
#define NICL 5
#define CAD 6
#define WIN 7
#define LWR 8
#define LWRL 9
#define LWRW 10
#define RSE 11
#define RSEL 12
#define RSEW 13
#define ADJ 14
#define ADJL 15
#define ADJW 16
#define MOV 17
#define MOVL 18
#define MOVW 19
#define NUM 20
#define BLE 21

&adc {
	status = "okay";
};

/ {
	// 左のジョイスティック（マウスカーソル移動用）
	anin0: analog_input_0 {
		compatible = "zmk,analog-input";
		sampling-hz = <100>;
		y-ch {
			io-channels = <&adc 0>; // Y軸がADCチャンネル0に接続
			mv-mid = <1555>; // Y軸のニュートラル（中央）でのミリボルト値
			mv-min-max = <2615>; // Y軸の最小/最大ミリボルト範囲
			mv-deadzone = <88>; // Y軸のデッドゾーン（感度を調整）
			scale-multiplier = <1>; // スケーリングの乗数
			scale-divisor = <50>; // スケーリングの除数
			#invert; // Y軸の入力を反転
			evt-type = <INPUT_EV_REL>; // 相対イベントタイプ
			input-code = <INPUT_REL_Y>; // Y軸の動きをマウスのY軸（垂直）にマッピング
		};
		x-ch {
			io-channels = <&adc 1>; // X軸がADCチャンネル1に接続
			mv-mid = <1576>; // X軸のニュートラル（中央）でのミリボルト値
			mv-min-max = <2460>; // X軸の最小/最大ミリボルト範囲
			mv-deadzone = <88>; // X軸のデッドゾーン
			scale-multiplier = <1>;
			scale-divisor = <50>;
			invert; // X軸の入力を反転
			evt-type = <INPUT_EV_REL>;
			input-code = <INPUT_REL_X>; // X軸の動きをマウスのX軸（水平）にマッピング
			#report-on-change-only;
		};
	};
	
	file_f: file_f { // ファイルの切り替え正
		compatible = "zmk,behavior-macro";
		wait-ms = <40>;
		tap-ms = <40>;
		#binding-cells = <0>;
		bindings
			= <&macro_press &kp LCTRL>
			, <&macro_tap &kp F6>
			, <&macro_release &kp LCTRL>
			;
    };
	file_r: file_r { // ファイルの切り替え逆
		compatible = "zmk,behavior-macro";
		wait-ms = <40>;
		tap-ms = <40>;
		#binding-cells = <0>;
		bindings
			= <&macro_press &kp LSHFT>
			, <&macro_press &kp LCTRL>
			, <&macro_tap &kp F6>
			, <&macro_release &kp LCTRL>
			, <&macro_release &kp LSHFT>
			;
    };
	pr_pg: pr_pg { // 前ページ切り替え
		compatible = "zmk,behavior-macro";
		wait-ms = <40>;
		tap-ms = <40>;
		#binding-cells = <0>;
		bindings
			= <&macro_press &kp LSHFT>
			, <&macro_tap &kp F5>
			, <&macro_release &kp LSHFT>
			;
    };
	nx_pg: nx_pg { // 次ページ切り替え
		compatible = "zmk,behavior-macro";
		wait-ms = <40>;
		tap-ms = <40>;
		#binding-cells = <0>;
		bindings
			= <&macro_press &kp LSHFT>
			, <&macro_tap &kp F6>
			, <&macro_release &kp LSHFT>
			;
    };
	int5_g: int5_g { // 端点再設定(AHK)
		compatible = "zmk,behavior-macro";
		#binding-cells = <0>;
		bindings
			= <&macro_press &kp INT5>
			, <&macro_wait_time 40>
			, <&macro_tap &kp G>
			, <&macro_wait_time 40>
			, <&macro_release &kp INT5>
			;
    };

	// ここから下はECAD用マクロ定義
        // =========================================================================
        // --- 2. Ctrl + A (<Key1> + Ctrl + A) ---
        // =========================================================================
        
	// Ctrl + A, A: 回転
	ctrl_a_a: ctrl_a_a {
		compatible = "zmk,behavior-macro";
		#binding-cells = <0>;
		bindings
			= <&macro_press &kp LCTRL>
			, <&macro_tap &kp A>, <&macro_release &kp LCTRL>
			, <&macro_tap &kp A>
			;
	};

	// Ctrl + A, B: 長方形(サイズ)
	ctrl_a_b: ctrl_a_b {
		compatible = "zmk,behavior-macro";
		#binding-cells = <0>;
		bindings
			= <&macro_press &kp LCTRL>
			, <&macro_tap &kp A>, <&macro_release &kp LCTRL>
			, <&macro_tap &kp B>
			;
	};

	// Ctrl + A, C: コピー
	ctrl_a_c: ctrl_a_c {
		compatible = "zmk,behavior-macro";
		#binding-cells = <0>;
		bindings
			= <&macro_press &kp LCTRL>
			, <&macro_tap &kp A>, <&macro_release &kp LCTRL>
			, <&macro_tap &kp C>
			;
	};

	// Ctrl + A, D: 補助線削除
	ctrl_a_d: ctrl_a_d {
		compatible = "zmk,behavior-macro";
		#binding-cells = <0>;
		bindings
			= <&macro_press &kp LCTRL>
			, <&macro_tap &kp A>, <&macro_release &kp LCTRL>
			, <&macro_tap &kp D>
			;
	};

	// Ctrl + A, E: 文字種別変更
	ctrl_a_e: ctrl_a_e {
		compatible = "zmk,behavior-macro";
		#binding-cells = <0>;
		bindings
			= <&macro_press &kp LCTRL>
			, <&macro_tap &kp A>, <&macro_release &kp LCTRL>
			, <&macro_tap &kp E>
			;
	};

	// Ctrl + A, F: 多相結線
	ctrl_a_f: ctrl_a_f {
		compatible = "zmk,behavior-macro";
		#binding-cells = <0>;
