			#input-processor-cells = <0>;
		track_remainders;
			bindings = <&kp E>     // 右：文字修正
	                 , <&kp T>     // 左：文字
					 , <&ctrl_d_e> // 上：文字種別変更
					 , <&ctrl_f_f> // 下：文章修正
					 ;
			tick = <150>;
			wait-ms = <100>;
			tap-ms = <50>;
			mode = <1>;
	        // threshold = <10>
	        // max_threshold = <200>
	        // max_pending_activations = <10>
    };
	zip_keybind_keys_ecad_radjw: zip_keybind_keys_ecad_radjw {
			compatible = "zmk,input-processor-keybind";
			#input-processor-cells = <0>;
		track_remainders;
			bindings = <&ctrl_d_w>     // 右：渡りページ編集
	                 , <&ctrl_d_r>     // 左：リファレンス編集
					 , <&ctrl_d_n>     // 上：自動線番
					 , <&ctrl_alt_s>   // 下：シンボル一覧[AHK]
					 ;
			tick = <150>;
			wait-ms = <100>;
			tap-ms = <50>;
			mode = <1>;
	        // threshold = <10>
	        // max_threshold = <200>
	        // max_pending_activations = <10>
    };
	zip_keybind_keys_ecad_rmovw: zip_keybind_keys_ecad_rmovw {
			compatible = "zmk,input-processor-keybind";
			#input-processor-cells = <0>;
		track_remainders;
			bindings = <&kp G>     // 右：図形グループ化
					 , <&ctrl_d_g> // 左：図形グループ化解除
	                 , <&kp W>     // 上：図形情報表示
					 , <&ctrl_d_d> // 下：補助線削除
					 ;
			tick = <150>;
			wait-ms = <100>;
			tap-ms = <50>;
			mode = <1>;
	        // threshold = <10>
	        // max_threshold = <200>
	        // max_pending_activations = <10>
    };
	zip_keybind_keys_ecad_rble: zip_keybind_keys_ecad_rble {
			compatible = "zmk,input-processor-keybind";
			#input-processor-cells = <0>;
		track_remainders;
			bindings = <&ctrl_f_v> // 右：ページ編集
					 , <&ctrl_d_z> // 左：全ページ情報
	                 , <&ctrl_d_x> // 上：図面管理情報
	                 , <&ctrl_d_y> // 下：ページ管理情報
					 ;
			tick = <150>;
			wait-ms = <100>;
			tap-ms = <50>;
			mode = <1>;
	        // threshold = <10>
	        // max_threshold = <200>
	        // max_pending_activations = <10>
    };
	zip_keybind_keys_browser: zip_keybind_keys_browser {
			compatible = "zmk,input-processor-keybind";
			#input-processor-cells = <0>;
		track_remainders;
			bindings = <&kp LC(ENTER)> // 右：新しいタブで開く
	                 , <&kp LC(W)>     // 左：タブを閉じる
					 , <&kp LS(TAB)>   // 上：前の項目へ戻る
	                 , <&kp TAB>       // 下：次の項目へ進む
					 ;
			tick = <150>;
			wait-ms = <100>;
			tap-ms = <50>;
			mode = <1>;
	        // threshold = <10>
	        // max_threshold = <200>
	        // max_pending_activations = <10>
    };
	zip_keybind_keys_browser_i: zip_keybind_keys_browser_i {
			compatible = "zmk,input-processor-keybind";
			#input-processor-cells = <0>;
		track_remainders;
			bindings = <&kp LG(T)>     // 右：新規タブを開く
	                 , <&kp LG(W)>     // 左：タブを閉じる
					 , <&kp LS(SPACE)> // 上：上へ戻る
	                 , <&kp SPACE>     // 下：下へ進む
					 ;
			tick = <150>;
			wait-ms = <100>;
			tap-ms = <50>;
			mode = <1>;
	        // threshold = <10>
	        // max_threshold = <200>
	        // max_pending_activations = <10>
    };
	zip_keybind_keys_media: zip_keybind_keys_media {
			compatible = "zmk,input-processor-keybind";
			#input-processor-cells = <0>;
		track_remainders;
			bindings = <&kp C_FF>     // 右：早送り
					  ,<&kp C_RW>     // 左：巻き戻し
					  ,<&kp C_VOL_UP> // 上：音量アップ
					  ,<&kp C_VOL_DN> // 下：音量ダウン
					  ;
			tick = <60>;
			wait-ms = <0>;
			tap-ms = <10>;
	};

