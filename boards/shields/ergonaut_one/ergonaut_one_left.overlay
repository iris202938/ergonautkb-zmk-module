	ctrl_f_f: ctrl_f_f { // 文章修正
		compatible = "zmk,behavior-macro";
		#binding-cells = <0>;
		bindings
			= <&macro_press &kp LCTRL>
			, <&macro_tap &kp F>
			, <&macro_release &kp LCTRL>
			, <&macro_tap &kp F>
			;
    };
	ctrl_d_f: ctrl_d_f { // 多相結線
		compatible = "zmk,behavior-macro";
		#binding-cells = <0>;
		bindings
			= <&macro_press &kp LCTRL>
			, <&macro_tap &kp D>
			, <&macro_release &kp LCTRL>
			, <&macro_tap &kp F>
			;
    };
	ctrl_f_n: ctrl_f_n { // 三相線番
		compatible = "zmk,behavior-macro";
		#binding-cells = <0>;
		bindings
			= <&macro_press &kp LCTRL>
			, <&macro_tap &kp F>
			, <&macro_release &kp LCTRL>
			, <&macro_tap &kp N>
			;
    };
	ctrl_d_n: ctrl_d_n { // 自動線番範囲選択
		compatible = "zmk,behavior-macro";
		// wait-ms = <40>;
		// tap-ms = <40>;
		#binding-cells = <0>;
		bindings
			= <&macro_press &kp LCTRL>
			, <&macro_tap &kp D>
			, <&macro_release &kp LCTRL>
			, <&macro_tap &kp N>
			, <&macro_wait_time 80>
			, <&macro_tap &kp TAB>
			, <&macro_tap &kp TAB>
			, <&macro_tap &kp TAB>
			, <&to WIN> // ADJWのベースレイヤー（例としてWINレイヤー）に戻る※rsewレイヤロック強制解除用
			;
    };
	ctrl_d_a: ctrl_d_a { // ツイスト線
		compatible = "zmk,behavior-macro";
		#binding-cells = <0>;
		bindings
			= <&macro_press &kp LCTRL>
			, <&macro_tap &kp D>
			, <&macro_release &kp LCTRL>
			, <&macro_tap &kp A>
			;
    };
	ctrl_alt_s: ctrl_alt_s { // シンボル一覧(AHK)
		compatible = "zmk,behavior-macro";
		#binding-cells = <0>;
		bindings
			= <&macro_press &kp LCTRL>
			// , <&macro_wait_time 40>
			, <&macro_press &kp LALT>
			, <&macro_tap &kp S>
			, <&macro_release &kp LALT>
			// , <&macro_wait_time 40>
			, <&macro_release &kp LCTRL>
			, <&to WIN> // ADJWのベースレイヤー（例としてWINレイヤー）に戻る※rsewレイヤロック強制解除用
			;
    };	
	ctrl_d_w: ctrl_d_w { // 渡りページ編集
		compatible = "zmk,behavior-macro";
		#binding-cells = <0>;
		bindings
