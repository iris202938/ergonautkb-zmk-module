	ctrl_d_g: ctrl_d_g { // グループ化解除
		compatible = "zmk,behavior-macro";
		#binding-cells = <0>;
		bindings
			= <&macro_press &kp LCTRL>
			, <&macro_tap &kp D>
			, <&macro_release &kp LCTRL>
			, <&macro_tap &kp G>
			, <&to WIN> // ADJWのベースレイヤー（例としてWINレイヤー）に戻る※rsewレイヤロック強制解除用
			;
    };

	zip_keybind_keys_directionL: zip_keybind_keys_directionL {
			compatible = "zmk,input-processor-keybind";
			#input-processor-cells = <0>;
		track_remainders;
			bindings = <&kp RIGHT>
					  ,<&kp LEFT>
					  ,<&kp UP>
					  ,<&kp DOWN>
					  ;
			tick = <150>;
			wait-ms = <100>;
			tap-ms = <50>;
			mode = <1>;
	        // threshold = <10>
	        // max_threshold = <200>
	        // max_pending_activations = <10>
	};
	zip_keybind_keys_directionM: zip_keybind_keys_directionM {
			compatible = "zmk,input-processor-keybind";
			#input-processor-cells = <0>;
		track_remainders;
			bindings = <&kp RIGHT>
					  ,<&kp LEFT>
					  ,<&kp UP>
					  ,<&kp DOWN>
					  ;
			tick = <100>; // ティック間隔
			wait-ms = <5>; // 待機時間
			tap-ms = <10>; // タップ時間
	};
	zip_keybind_keys_directionH: zip_keybind_keys_directionH {
			compatible = "zmk,input-processor-keybind";
			#input-processor-cells = <0>;
		track_remainders;
			bindings = <&kp RIGHT>
					  ,<&kp LEFT>
					  ,<&kp UP>
					  ,<&kp DOWN>
					  ;
			tick = <50>; // ティック間隔
			wait-ms = <0>; // 待機時間
			tap-ms = <10>; // タップ時間
	};
	zip_keybind_keys_file: zip_keybind_keys_file {
			compatible = "zmk,input-processor-keybind";
			#input-processor-cells = <0>;
		track_remainders;
			bindings = <&nx_pg>  // 右：次ページ切り替え
					 , <&pr_pg>  // 左：前ページ切り替え
					 , <&file_r> // 上：ファイルの切り替え逆
					 , <&file_f> // 下：ファイルの切り替え正
					 ;
			tick = <150>;
			wait-ms = <100>;
			tap-ms = <50>;
			mode = <1>;
	        // threshold = <10>
	        // max_threshold = <200>
	        // max_pending_activations = <10>
    };
	zip_keybind_keys_ecad_rsew: zip_keybind_keys_ecad_rsew {
			compatible = "zmk,input-processor-keybind";
			#input-processor-cells = <0>;
		track_remainders;
			bindings = <&kp C>  // 右：複写
	                 , <&kp D>  // 左：削除
					 , <&kp A>  // 上：領域移動
	                 , <&kp Z>  // 下：属性変更
					 ;
			tick = <150>;
			wait-ms = <100>;
			tap-ms = <50>;
			mode = <1>;
	        // threshold = <10>
	        // max_threshold = <200>
	        // max_pending_activations = <10>
    };
	zip_keybind_keys_ecad_ladjw: zip_keybind_keys_ecad_ladjw {
