	// =========================================================================
	// --- 3. Ctrl + D (<Key1> + Ctrl + D) ---
	// =========================================================================

	// Ctrl + D, A: 拡大・縮小
	ctrl_d_a: ctrl_d_a {
		compatible = "zmk,behavior-macro";
		#binding-cells = <0>;
		bindings
			= <&macro_press &kp LCTRL>
			, <&macro_tap &kp D>, <&macro_release &kp LCTRL>
			, <&macro_tap &kp A>
			;
	};

	// Ctrl + D, B: 面取り
	ctrl_d_b: ctrl_d_b {
		compatible = "zmk,behavior-macro";
		#binding-cells = <0>;
		bindings
			= <&macro_press &kp LCTRL>
			, <&macro_tap &kp D>, <&macro_release &kp LCTRL>
			, <&macro_tap &kp B>
			;
	};

	// Ctrl + D, C: 円弧(中心)
	ctrl_d_c: ctrl_d_c {
		compatible = "zmk,behavior-macro";
		#binding-cells = <0>;
		bindings
			= <&macro_press &kp LCTRL>
			, <&macro_tap &kp D>, <&macro_release &kp LCTRL>
			, <&macro_tap &kp C>
			;
	};

	// Ctrl + D, D: 補助線全削除
	ctrl_d_d: ctrl_d_d {
		compatible = "zmk,behavior-macro";
		#binding-cells = <0>;
		bindings
			= <&macro_press &kp LCTRL>
			, <&macro_tap &kp D>, <&macro_release &kp LCTRL>
			, <&macro_tap &kp D>
			;
	};

	// Ctrl + D, E: 文章修正
	ctrl_d_e: ctrl_d_e {
		compatible = "zmk,behavior-macro";
		#binding-cells = <0>;
		bindings
			= <&macro_press &kp LCTRL>
			, <&macro_tap &kp D>, <&macro_release &kp LCTRL>
			, <&macro_tap &kp E>
