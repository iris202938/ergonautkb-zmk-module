	// Ctrl + A, M: 上下中央間隔揃え
	ctrl_a_m: ctrl_a_m {
		compatible = "zmk,behavior-macro";
		#binding-cells = <0>;
		bindings
			= <&macro_press &kp LCTRL>
			, <&macro_tap &kp A>, <&macro_release &kp LCTRL>
			, <&macro_tap &kp M>
