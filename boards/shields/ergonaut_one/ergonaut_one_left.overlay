	// Ctrl + A, K: コメント
	ctrl_a_k: ctrl_a_k {
		compatible = "zmk,behavior-macro";
		#binding-cells = <0>;
		bindings
			= <&macro_press &kp LCTRL>
			, <&macro_tap &kp A>, <&macro_release &kp LCTRL>
			, <&macro_tap &kp K>
			;
	};

	// Ctrl + A, L: 直線(中心線)
	ctrl_a_l: ctrl_a_l {
		compatible = "zmk,behavior-macro";
		#binding-cells = <0>;
		bindings
			= <&macro_press &kp LCTRL>
			, <&macro_tap &kp A>, <&macro_release &kp LCTRL>
			, <&macro_tap &kp L>
			;
