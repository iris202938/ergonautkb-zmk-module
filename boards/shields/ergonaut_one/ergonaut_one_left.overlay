	ctrl_a_v: ctrl_a_v { // 貼付け
		compatible = "zmk,behavior-macro";
		#binding-cells = <0>;
		bindings
			= <&macro_press &kp LCTRL>
			, <&macro_tap &kp A>
			, <&macro_release &kp LCTRL>
			, <&macro_tap &kp V>
