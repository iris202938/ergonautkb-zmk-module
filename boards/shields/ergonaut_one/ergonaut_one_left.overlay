	// Ctrl + D, H: 文字列検索
	ctrl_d_h: ctrl_d_h {
		compatible = "zmk,behavior-macro";
		#binding-cells = <0>;
		bindings
			= <&macro_press &kp LCTRL>
			, <&macro_tap &kp D>, <&macro_release &kp LCTRL>
			, <&macro_tap &kp H>
			;
