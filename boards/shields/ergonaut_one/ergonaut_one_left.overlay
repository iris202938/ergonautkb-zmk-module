			, <&macro_tap &kp D>, <&macro_release &kp LCTRL>
			, <&macro_tap &kp V>
			;
	};

	// Ctrl + D, W: 一時補助線全削除
	ctrl_d_w: ctrl_d_w {
		compatible = "zmk,behavior-macro";
		#binding-cells = <0>;
		bindings
			= <&macro_press &kp LCTRL>
			, <&macro_tap &kp D>, <&macro_release &kp LCTRL>
			, <&macro_tap &kp W>
			;
	};

	// Ctrl + D, X: 長円
	ctrl_d_x: ctrl_d_x {
