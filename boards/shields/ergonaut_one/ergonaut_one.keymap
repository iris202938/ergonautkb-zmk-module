		bindings = <&kp RSHIFT>;
	};

	combo_TSHIFTN {
		timeout-ms = <80>;
		key-positions = <36 41>;
		layers = <NIC NICL>;
		bindings = <&qm RSHIFT>;
	};

	combo_ALT_INT4 { // ECADの選択位置移動(複写)(AHK)
		timeout-ms = <80>;
		key-positions = <32 33>;
		layers = <RSEW>;
		bindings = <&alt_int4>; //変換
	};

	combo_ALT_INT5 { // ECADの選択位置移動(移動)(AHK)
		timeout-ms = <80>;
		key-positions = <31 32>;
		layers = <RSEW>;
		bindings = <&alt_int5>; //無変換
	};

